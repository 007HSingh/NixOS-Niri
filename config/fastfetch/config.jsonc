{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    "type": "file",
    "source": "~/.config/fastfetch/cat.txt",
    "color": {
      "1": "cyan"
    },
    "padding": {
      "top": 2,
      "left": 2
    }
  },
  "display": {
    "separator": " ❯ ",
    "color": {
      "keys": "magenta"
    }
  },
  "modules": [
    "break",
    {
      "type": "title",
      "key": "",
      "format": "{user-name}@{host-name}"
    },
    {
      "type": "os",
      "key": "󱄅",
      "format": "{3} {12}"
    },
    {
      "type": "kernel",
      "key": ""
    },
    {
      "type": "uptime",
      "key": "󱎫"
    },
    {
      "type": "packages",
      "key": "󰏖"
    },
    {
      "type": "wm",
      "key": ""
    },
    {
      "type": "terminal",
      "key": ""
    },
    {
      "type": "memory",
      "key": "󰍛"
    }
  ]
}
